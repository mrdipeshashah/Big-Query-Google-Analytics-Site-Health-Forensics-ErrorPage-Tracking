SELECT 
  Date,
  Step_Count,
  Heart_Rate,
  Distance_km,
  Gym_YN,
  
  -- 1. Date Dimensions (For time-series analysis)
  FORMAT_DATE('%Y-%m', Date) AS month_year,
  EXTRACT(ISOWEEK FROM Date) AS week_number,
  EXTRACT(MONTH FROM Date) AS month_number,
  FORMAT_DATE('%B', Date) AS month_name,
  EXTRACT(YEAR FROM Date) AS year_number,
  
  -- 2. Gym Counter (Boolean to Integer conversion)
  CASE WHEN Gym_YN = 'Y' THEN 1 ELSE 0 END AS gym_count,
  
  -- 3. Human Engine: Efficiency (Steps per Heartbeat)
  -- Uses NULLIF to avoid division by zero errors
  ROUND(Step_Count / NULLIF(Heart_Rate, 0), 2) AS efficiency_mpg,
  
  -- 4. Human Engine: Capacity Score (Efficiency x Scaling Factor)
  -- Standardizing at 30 to match your 2025 performance dashboard
  ROUND((Step_Count / NULLIF(Heart_Rate, 0)) * 30, 0) AS capacity_score,

  -- 5. Efficiency Delta (Example of a calculated flag)
  -- Helps identify "High Performance" days (e.g., above your 55 MPG target)
  CASE 
    WHEN (Step_Count / NULLIF(Heart_Rate, 0)) >= 55 THEN 'High Efficiency'
    ELSE 'Standard'
  END AS performance_tier

FROM `enter.tablename_123456.events_*`
ORDER BY Date DESC
